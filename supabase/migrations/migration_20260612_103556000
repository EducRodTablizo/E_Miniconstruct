
-- Historical Reports table for MC018/MC019
CREATE TABLE IF NOT EXISTS historical_reports (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  report_type TEXT NOT NULL CHECK (report_type IN ('daily','weekly','monthly','yearly')),
  period_label TEXT NOT NULL,
  period_start TIMESTAMPTZ NOT NULL,
  period_end   TIMESTAMPTZ NOT NULL,
  total_sales  NUMERIC NOT NULL DEFAULT 0,
  total_transactions INTEGER NOT NULL DEFAULT 0,
  inventory_changes JSONB DEFAULT '[]'::jsonb,
  user_activities   JSONB DEFAULT '[]'::jsonb,
  audit_summary     JSONB DEFAULT '[]'::jsonb,
  generated_by UUID REFERENCES profiles(id),
  created_at TIMESTAMPTZ DEFAULT NOW()
);

ALTER TABLE historical_reports ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Privileged users can manage historical_reports" ON historical_reports
  FOR ALL TO authenticated
  USING (is_owner())
  WITH CHECK (is_owner());

-- Enable realtime for historical reports
ALTER PUBLICATION supabase_realtime ADD TABLE historical_reports;
